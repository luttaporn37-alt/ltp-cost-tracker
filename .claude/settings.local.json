{
  "permissions": {
    "allow": [
      "PowerShell(npx create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --no-git --yes 2>&1)",
      "PowerShell(npm install *)",
      "PowerShell(Get-ChildItem -Recurse -Depth 2 | Where-Object { !$_.FullName.Contains\\('node_modules'\\) -and !$_.FullName.Contains\\('.next'\\) } | Select-Object FullName | Format-Table -AutoSize)",
      "PowerShell(git *)",
      "Bash(git init *)",
      "Bash(git add *)"
    ]
  }
}
